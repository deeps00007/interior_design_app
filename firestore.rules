rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isUserOwnerRole() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }
    
    // Properties collection
    match /properties/{propertyId} {
      // Anyone can read properties
      allow read: if true;
      
      // Only authenticated owner users can create/update properties
      allow create: if isSignedIn() && isUserOwnerRole();
      allow update: if isSignedIn() && isUserOwnerRole();
      
      // Only property owner can delete
      allow delete: if isSignedIn() && 
                      resource.data.ownerId == request.auth.uid;
    }
    
    // Users collection
    match /users/{userId} {
      // Users can read their own data, OR owners can read all users (for broadcast)
      allow read: if isOwner(userId) || isUserOwnerRole();
      
      // Users can create/update their own data
      allow create, update: if isOwner(userId);
      
      // Only user can delete their own data
      allow delete: if isOwner(userId);
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // All signed-in users can read notifications (used for global broadcasts)
      allow read: if isSignedIn();
      
      // Only server/admin can create notifications (via backend)
      // For now, allowing authenticated users to create (or admins)
      allow create: if isSignedIn();
      
      // Users can update/delete notifications
      allow update, delete: if isSignedIn();
    }
  }
}
